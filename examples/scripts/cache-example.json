{
  "schema_version": 1,
  "script_id": "01JAN3XSCACHE001",
  "request_hash": "sha256-abc123def456",
  "version": 1,
  "normalized_request": "split flac cue album into separate tracks",
  "match_policy": "exact_normalized",
  "risk": "local_write",
  "scope": {
    "cwd_policy": "any_cwd_with_parameters",
    "cwd": "/home/user/music"
  },
  "parameters": {
    "flac_file": {"source": "glob_one", "pattern": "*.flac", "required": true},
    "cue_file": {"source": "glob_one", "pattern": "*.cue", "required": true},
    "output_dir": {"source": "default", "value": "./tracks"}
  },
  "preconditions": [
    {"binary_exists": "ffmpeg"},
    {"glob_one": "*.flac"},
    {"glob_one": "*.cue"}
  ],
  "steps": [
    {
      "command": "mkdir",
      "argv": ["-p", "${output_dir}"],
      "risk": "local_write",
      "description": "Create output directory"
    },
    {
      "command": "ffmpeg",
      "argv": [
        "-i", "${flac_file}",
        "-i", "${cue_file}",
        "-map", "0:0",
        "-c", "copy",
        "-f", "segment",
        "-segment_times", "0 180 360 540",
        "${output_dir}/track_%02d.flac"
      ],
      "risk": "local_write",
      "description": "Split FLAC by CUE timings (illustrative — segment_times computed per album in production)",
      "timeout_secs": 300
    }
  ],
  "artifacts": [
    {"path_glob": "${output_dir}/*.flac", "kind": "created_file"}
  ],
  "success_count": 0,
  "trust_threshold": 3,
  "created_at": "2026-06-23T12:00:00Z",
  "last_used_at": "2026-06-23T12:00:00Z"
}
