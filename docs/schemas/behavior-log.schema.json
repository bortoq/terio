{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Behavior Log Schema (v1)",
  "description": "Схема записи в JSONL-логе поведения terio. Все записи имеют общие поля + поля специфичные для kind.",
  "type": "object",
  "required": [
    "schema_version", "instance_id", "session_id", "ts", "kind",
    "display_profile", "cost_counters"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "enum": [1],
      "description": "Версия схемы"
    },
    "instance_id": {
      "type": "string",
      "description": "ULID экземпляра terio (генерируется при первом запуске, не меняется)"
    },
    "session_id": {
      "type": "string",
      "format": "uuid",
      "description": "UUID сессии (один запуск terio)"
    },
    "interaction_id": {
      "type": "string",
      "format": "uuid",
      "description": "UUID одного запроса пользователя. Группирует пары (запрос → ответ). Обязателен для agent_turn, command_run, script_run."
    },
    "ts": {
      "type": "string",
      "format": "date-time",
      "description": "Время события (ISO8601)"
    },
    "kind": {
      "type": "string",
      "enum": ["agent_turn", "command_run", "script_run", "system_event"],
      "description": "Тип записи"
    },
    "display_profile": {
      "type": "object",
      "description": "Как показывать эту запись пользователю.",
      "required": ["type", "renderer_hint", "user_visible"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["auto", "text", "table", "media", "hidden", "summary"],
          "description": "Тип отображения"
        },
        "renderer_hint": {
          "type": "string",
          "enum": ["auto", "table", "plain", "timeline", "card"],
          "description": "Подсказка для renderer"
        },
        "user_visible": {
          "type": "boolean",
          "description": "Показывать пользователю или скрыть"
        },
        "summary_max_lines": {
          "type": "integer",
          "minimum": 1,
          "description": "Для type: summary — сколько строк показывать"
        }
      }
    },
    "cost_counters": {
      "type": "object",
      "description": "Сырые счётчики расходов для будущей total_attention_cost.",
      "required": ["observation_cost_hint", "llm_cost", "execution_cost", "cache_cost", "storage_cost"],
      "properties": {
        "observation_cost_hint": {
          "type": "object",
          "description": "Секунд внимания пользователя (MVP: заглушка, всегда 0.0)",
          "required": ["user_sec"],
          "properties": {
            "user_sec": { "type": "number", "minimum": 0 }
          }
        },
        "llm_cost": {
          "type": "object",
          "required": ["tokens", "duration_ms"],
          "properties": {
            "tokens": { "type": "integer", "minimum": 0 },
            "duration_ms": { "type": "integer", "minimum": 0 }
          }
        },
        "execution_cost": {
          "type": "object",
          "required": ["duration_ms", "commands_executed", "bytes_read", "bytes_written"],
          "properties": {
            "duration_ms": { "type": "integer", "minimum": 0 },
            "commands_executed": { "type": "integer", "minimum": 0 },
            "bytes_read": { "type": "integer", "minimum": 0 },
            "bytes_written": { "type": "integer", "minimum": 0 }
          }
        },
        "cache_cost": {
          "type": "object",
          "required": ["lookup_ms", "hit"],
          "properties": {
            "lookup_ms": { "type": "integer", "minimum": 0 },
            "hit": { "type": "boolean" }
          }
        },
        "storage_cost": {
          "type": "object",
          "required": ["bytes_written", "bytes_read"],
          "properties": {
            "bytes_written": { "type": "integer", "minimum": 0 },
            "bytes_read": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    "request": { "type": "string", "description": "Текст запроса" },
    "parent_interaction_id": { "type": "string", "format": "uuid", "description": "interaction_id родительского запроса (если один запрос породил другой)" },
    "cwd": { "type": "string", "description": "Рабочая директория" },
    "risk": { "type": "string", "enum": ["read_only", "local_write", "destructive", "network_read", "network_write", "credential_access", "financial"] },
    "status": { "type": "string", "enum": ["success", "failed", "cancelled"] },
    "failure_kind": { "type": "string", "description": "Тип ошибки, если status=failed" },
    "prompt_summary": { "type": "string", "maxLength": 512, "description": "Краткое содержание запроса к модели (с редэкцией)" },
    "plan": { "type": "array", "description": "План команд от модели" },
    "model_provider": { "type": "string" },
    "model_name": { "type": "string" },
    "duration_ms": { "type": "integer", "minimum": 0 },
    "tokens_used": { "type": "integer", "minimum": 0 },
    "command": { "type": "object", "description": "Выполненная команда (для command_run)" },
    "exit": { "type": "integer", "description": "Exit code" },
    "stdout_summary": { "type": ["string", "null"], "maxLength": 1024 },
    "stderr_summary": { "type": ["string", "null"], "maxLength": 1024 },
    "script_id": { "type": "string", "description": "ID скрипта из кеша (для script_run)" },
    "cache_hit": { "type": "boolean" },
    "model_called": { "type": "boolean" },
    "tokens_saved_estimate": { "type": "integer", "minimum": 0 },
    "success_count_before": { "type": "integer", "minimum": 0 },
    "success_count_after": { "type": "integer", "minimum": 0 },
    "steps": { "type": "array", "description": "Шаги выполнения (для script_run)" }
  },
  "allOf": [
    {
      "description": "agent_turn — запрос к модели",
      "if": { "properties": { "kind": { "const": "agent_turn" } } },
      "then": {
        "required": ["interaction_id", "request", "cwd", "risk", "status", "plan", "model_provider", "model_name", "duration_ms", "tokens_used"]
      }
    },
    {
      "description": "command_run — выполнение shell-команды",
      "if": { "properties": { "kind": { "const": "command_run" } } },
      "then": {
        "required": ["interaction_id", "request", "cwd", "risk", "status", "command", "exit", "duration_ms"]
      }
    },
    {
      "description": "script_run — выполнение скрипта из кеша",
      "if": { "properties": { "kind": { "const": "script_run" } } },
      "then": {
        "required": ["interaction_id", "request", "cwd", "risk", "status", "script_id", "cache_hit", "model_called", "steps", "duration_ms"]
      }
    },
    {
      "description": "system_event — системные события (interaction_id не требуется)",
      "if": { "properties": { "kind": { "const": "system_event" } } },
      "then": {
        "required": ["status"]
      }
    }
  ]
}
